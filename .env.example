# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── Security ────────────────────────────────────────────
# Set this to protect your API with a key
# Leave empty for open access
API_KEY=

# Comma-separated allowed origins for CORS (leave empty for *)
ALLOWED_ORIGINS=

# ─── Rate Limiting ────────────────────────────────────────
# Max requests per 15 minutes per IP
RATE_LIMIT=100

# ─── yt-dlp ──────────────────────────────────────────────
# Custom path to yt-dlp binary (leave empty to use PATH)
YTDLP_PATH=

# ─── Storage ─────────────────────────────────────────────
# Where downloaded files are saved
DOWNLOAD_DIR=./downloads

# SQLite database path
DB_PATH=./data/history.db
